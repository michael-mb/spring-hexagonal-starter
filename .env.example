# Keycloak JWT validation
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/starter
KEYCLOAK_JWK_SET_URI=http://localhost:8080/realms/starter/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=starter-app

# Keycloak Admin API
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=starter
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Active profile
ACTIVE_PROFILE=development
